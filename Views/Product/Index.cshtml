@model IEnumerable<Category>
<div id="User" style="display:none;" data-email="@User.Identity.Name" data-customer="@User.IsInRole("northwind-customer")" data-employee="@User.IsInRole("northwind-employee")"></div>

<div class="row align-items-end mb-4 g-3">
    <div class="col-md-4">
        <label for="CategoryId" class="form-label small fw-bold text-muted text-uppercase">Category</label>
        <select class="form-select shadow-sm" id="CategoryId">
            @foreach (Category c in Model)
            {
                if (c.CategoryId == ViewBag.id)
                { <option value="@c.CategoryId" selected>@c.CategoryName</option> }
                else
                { <option value="@c.CategoryId">@c.CategoryName</option> }
            }
        </select>
    </div>
    <div class="col-md-auto">
        <div class="form-check form-switch pb-2">
            <input class="form-check-input" type="checkbox" role="switch" id="Discontinued">
            <label class="form-check-label small fw-bold text-muted text-uppercase" for="Discontinued">Show Discontinued</label>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th scope="col" class="ps-4">Product Name</th>
                    <th scope="col" class="text-end">Price</th>
                    <th scope="col" class="text-end pe-4">Stock Status</th>
                </tr>
            </thead>
            <tbody id="product_rows" data-id="@ViewBag.id">
                <!-- Rows populated by JS -->
            </tbody>
        </table>
    </div>
</div>

<div id="cartModal" class="modal fade" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-light">
                <h5 class="modal-title fw-bold"><i class="bi bi-cart-plus me-2 text-primary"></i> Add to Cart</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div style="display:none;" id="ProductId"></div>
                <div class="row g-3">
                    <div class="col-12">
                        <label class="small text-muted text-uppercase fw-bold mb-1 d-block">Product</label>
                        <div class="h5 fw-bold mb-0" id="ProductName">Cool Product</div>
                    </div>
                    <div class="col-4">
                        <label class="small text-muted text-uppercase fw-bold mb-1 d-block">Price</label>
                        <div class="h6 mb-0">$<span id="UnitPrice">9.99</span></div>
                    </div>
                    <div class="col-4">
                        <label class="small text-muted text-uppercase fw-bold mb-1 d-block" for="Quantity">Quantity</label>
                        <input type="number" min="1" value="1" id="Quantity" class="form-control form-control-sm" />
                    </div>
                    <div class="col-4 text-end">
                        <label class="small text-muted text-uppercase fw-bold mb-1 d-block">Total</label>
                        <div class="h6 fw-bold text-primary mb-0">$<span id="Total">0.00</span></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer bg-light border-0">
                <button type="button" class="btn btn-link text-muted text-decoration-none" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary rounded-pill px-4" id="addToCart">Add to Cart</button>
            </div>
        </div>
    </div>
</div>
<div class="toast-container position-fixed bottom-0 end-0 p-3">
  <div id="liveToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
    <div class="toast-header">
      <strong class="me-auto" id="toast_header">Toast Header</strong>
      <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
    </div>
    <div class="toast-body" id="toast_body">
      Toast Message
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="../../product.js"></script>

