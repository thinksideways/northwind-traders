@model IEnumerable<Discount>

<div class="py-5 mb-5 text-center bg-white rounded-4 shadow-sm border">
    <div class="container py-4">
        <h1 class="display-3 fw-bold text-dark mb-3">
            Premium Food & Beverages
        </h1>
        <p class="col-lg-8 mx-auto fs-4 text-muted mb-4">
            Discover the finest selection of high-quality international cuisine. From rare delicacies to everyday favorites, we bring the world's best flavors to your doorstep.
        </p>
        <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
            <a class="btn btn-primary btn-lg px-5 rounded-pill shadow" asp-controller="Product" asp-action="Category">
                <i class="bi bi-shop me-2"></i> Browse Products
            </a>
            <a class="btn btn-outline-secondary btn-lg px-5 rounded-pill" href="#discount-row">
                View Deals
            </a>
        </div>
    </div>
</div>

<div class="row align-items-center mb-4">
    <div class="col">
        <h2 class="h3 mb-0">Featured Discounts</h2>
        <p class="text-muted small">Limited time offers on our most popular items</p>
    </div>
    <div class="col-auto">
        <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-2">Updated Today</span>
    </div>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 featured" id="discount-row">
    @foreach (Discount d in Model)
    {
        <div class="col">
            <div class="discounts h-100 d-flex flex-column shadow-sm border-0">
                <div class="mb-auto">
                    <h4 class="h5">@d.Title</h4>
                    <p class="text-muted small mb-3">@d.Description</p>
                </div>
                <div class="mt-3 pt-3 border-top">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="small text-muted"><i class="bi bi-clock me-1"></i> Expires: @d.EndTime.ToString("MM/dd/yyyy")</span>
                    </div>
                    <a href="#" data-code="@d.Code" data-title="@d.Title" data-product="@d.Product.ProductName" class="discount w-100 text-center">
                        <i class="bi bi-tag-fill me-1"></i> Get Discount Code
                    </a>
                </div>
            </div>
        </div>
    }
</div>
<!-- toast -->
<div class="toast-container position-fixed bottom-0 end-0 p-3">
  <div id="liveToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
    <div class="toast-header">
      <strong class="me-auto" id="product">Product</strong>
      <small class="text-body-secondary" id="title">just now</small>
      <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
    </div>
    <div class="toast-body">
      Discount Code: <span id="code">Code</span>
    </div>
  </div>
</div>
<script type="text/javascript" src="~/discount.js"></script>
